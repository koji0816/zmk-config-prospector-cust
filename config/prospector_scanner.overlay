#include <zephyr/dt-bindings/display/panel.h>

/*
 * 既存の四角いディスプレイ（st7789v）のノードをそのまま使い回し、
 * 中身を丸型ディスプレイ（GC9A01）の仕様にすり替える作戦です。
 * これにより重複エラーやラベル参照エラーが100%発生しなくなります。
 */
&st7789v {
    status = "okay";
    compatible = "galaxycore,gc9x01x";
    cmd-data-gpios = <&xiao_d 3 GPIO_ACTIVE_HIGH>;
    pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
    width = <240>;
    height = <240>;
    display-inversion;
};

&xiao_spi {
    /* XIAO Round DisplayのCSピン(D1)で上書き */
    cs-gpios = <&xiao_d 1 GPIO_ACTIVE_LOW>;
};
