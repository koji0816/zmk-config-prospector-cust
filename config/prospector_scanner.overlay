#include <zephyr/dt-bindings/display/panel.h>

/ {
    chosen {
        /* 画面の出力先を、新設する丸型ディスプレイに向ける */
        zephyr,display = &gc9a01;
    };
};

/* 元のモジュールがKconfig上で CST816S を強制要求するため、ダミーのエントリを作成してビルドエラーを回避する。
 * 通信や割り込みピンには使っていないピン(P0.02)をアサインして悪影響が出ないようにする。 */
&touch_sensor {
    status = "okay";
    /delete-property/ irq-gpios;
    /delete-property/ rst-gpios;
    irq-gpios = <&xiao_d 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    rst-gpios = <&xiao_d 0 GPIO_ACTIVE_LOW>;
};

/* XIAO Round Display のタッチセンサー (CHSC6416) を I2C0 に追加 */
&i2c0 {
    status = "okay";
    chsc6x_touch: chsc6x@2e {
        compatible = "chipsemi,chsc6x";
        reg = <0x2e>;
        irq-gpios = <&xiao_d 7 GPIO_ACTIVE_LOW>;
        /* width/height properties can be configured here if necessary */
    };
};

/* 既存の四角ディスプレイは、中身をいじらずに電源だけ切る（エラー回避） */
&st7789v {
    status = "disabled";
};



/* * SPIバスの管理枠を2つに増やします。
 * [0] = 元のディスプレイ用 (ダミーとして残す)
 * [1] = 新しい丸型ディスプレイ用 (CSピン = D1)
 */
&xiao_spi {
    status = "okay";
    cs-gpios = <&xiao_d 9 GPIO_ACTIVE_LOW>, <&xiao_d 1 GPIO_ACTIVE_LOW>;
};

/* ディスプレイの通信バス（MIPI-DBI）の設定を上書き */
&{/mipi_dbi} {
    /* SPI通信のデバイスを xiao_spi (デフォルトSPI2) に向けるように変更 */
    spi-dev = <&xiao_spi>;

    /* XIAO Round Display の DCピン(D3) に変更 */
    dc-gpios = <&xiao_d 3 GPIO_ACTIVE_HIGH>;
    /* D3ピンが元のリセットピン設定と被るのを防ぐため、リセット設定を消去 */
    /delete-property/ reset-gpios;

    /* アドレス「1」に、丸型ディスプレイを新規登録する */
    gc9a01: gc9x01x@1 {
        status = "okay";
        compatible = "galaxycore,gc9x01x";
        reg = <1>;  /* cs-gpios の [1] 番目を使うという意味 */
        mipi-max-frequency = <20000000>;
        pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
        width = <240>;
        height = <240>;
        /* Hardware rotation: Type-C port at the bottom (90 degrees CW) */
        orientation = "90";
    };
};
